{
  "name": "agroafrica-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "description": "AgroAfrica — Le Grand Marché Agricole & Artisanal Africain",
  "author": "AgroAfrica Team",
  "license": "MIT",
  "engines": {
    "node": ">=18.x",
    "npm": ">=9.x"
  },
  "scripts": {
    "dev": "vite",
    "build": "vite build",
    "preview": "vite preview",
    "preview:prod": "vite preview --mode production",
    "lint": "eslint . --ext js,jsx --report-unused-disable-directives --max-warnings 0",
    "lint:fix": "eslint . --ext js,jsx --fix",
    "format": "prettier --write \"src/**/*.{js,jsx,css}\"",
    "format:check": "prettier --check \"src/**/*.{js,jsx,css}\"",
    "check": "npm run lint && npm run build",
    "clean": "rm -rf dist node_modules/.vite",
    "seed": "node scripts/seedDatabase.js",
    "seed:local": "API_BASE_URL=http://localhost:5000/api node scripts/seedDatabase.js",
    "deploy": "npm run build",
    "analyze": "vite build --mode analyze",
    "postinstall": "node scripts/fixNodeBinPermissions.mjs"
  },
  "dependencies": {
    "@reduxjs/toolkit": "^2.2.7",
    "axios": "^1.7.7",
    "lucide-react": "^0.460.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "react-redux": "^9.1.2",
    "react-router-dom": "^6.27.0",
    "redux-persist": "^6.0.0"
  },
  "devDependencies": {
    "@eslint/js": "^9.12.0",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^4.3.2",
    "autoprefixer": "^10.4.20",
    "eslint": "^9.12.0",
    "eslint-plugin-react": "^7.37.1",
    "eslint-plugin-react-hooks": "^5.0.0",
    "eslint-plugin-react-refresh": "^0.4.12",
    "globals": "^15.10.0",
    "postcss": "^8.4.47",
    "prettier": "^3.3.3",
    "tailwindcss": "^3.4.13",
    "vite": "^5.4.8",
    "vite-plugin-pwa": "^0.20.5"
  },
  "browserslist": {
    "production": [
      ">0.2%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 1 chrome version",
      "last 1 firefox version",
      "last 1 safari version"
    ]
  },
  "volta": {
    "node": "20.11.0",
    "npm": "10.2.4"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/ismaeldaniel653-droid/agroafrica-frontend.git"
  },
  "bugs": {
    "url": "https://github.com/ismaeldaniel653-droid/agroafrica-frontend/issues"
  },
  "homepage": "https://agroafrica-frontend.vercel.app",
  "keywords": [
    "agroafrica",
    "agriculture",
    "artisanat",
    "e-commerce",
    "africa",
    "mobile-money",
    "react",
    "vite"
  ]
}